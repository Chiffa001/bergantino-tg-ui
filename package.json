{
  "name": "bergantino-tg-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-stage": "npm run lint && npm run check && npm run test && npm run build",
    "prepare": "husky",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:screenshots": "SAVE_SCREENSHOTS=1 playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.28.0",
    "vite": "^8.0.1",
    "vite-plugin-mkcert": "^1.17.8",
    "vitest": "^4.1.1",
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2"
  },
  "dependencies": {
    "@chiffa001/tg-svelte-ui": "^0.0.17",
    "@tanstack/svelte-query": "^6.1.10",
    "@tma.js/sdk-svelte": "^1.0.16"
  }
}
